{
    "widgets": [
        {
            "type": "alarm",
            "x": 0, "y": 0, "width": 24, "height": 2,
            "properties": {
                "title": "Alarm Status",
                "alarms": [
                    "arn:aws:cloudwatch:us-east-2:ACCOUNT_ID:alarm:week8-alb-5xx-rate",
                    "arn:aws:cloudwatch:us-east-2:ACCOUNT_ID:alarm:week8-asg-instance-count-low",
                    "arn:aws:cloudwatch:us-east-2:ACCOUNT_ID:alarm:week8-rds-cpu-high",
                    "arn:aws:cloudwatch:us-east-2:ACCOUNT_ID:alarm:week8-critical-outage"
                ]
            }
        },
        {
            "type": "metric",
            "x": 0, "y": 2, "width": 12, "height": 6,
            "properties": {
                "title": "ALB Request Count & 5xx Errors",
                "metrics": [
                    ["AWS/ApplicationELB", "RequestCount", "LoadBalancer", "app/week8-alb/b1f25f60812b5fc1"],
                    ["AWS/ApplicationELB", "HTTPCode_ELB_5XX_Count", "LoadBalancer", "app/week8-alb/b1f25f60812b5fc1"]
                ],
                "period": 60,
                "stat": "Sum",
                "region": "us-east-2",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "x": 12, "y": 2, "width": 12, "height": 6,
            "properties": {
                "title": "ALB Target Response Time & Healthy Hosts",
