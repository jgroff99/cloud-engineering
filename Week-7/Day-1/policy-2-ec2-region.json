{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowDescribeInstancesUSEast1Only",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    }
  ]
}
